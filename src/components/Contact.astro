---
import { resumeData } from '../data/resume';
---

<section class="py-24 border-t" style="background-color: var(--color-surface-container-low); border-color: rgba(65, 71, 84, 0.1)" id="contact">
  <div class="max-w-4xl mx-auto px-6 flex flex-col items-center">
    <div class="mb-12 text-center">
      <h2
        class="text-3xl font-bold headline-font tracking-tighter uppercase mb-4"
        data-i18n-base
        data-i18n-en="Contact"
        data-i18n-de="Kontakt"
      >Contact</h2>
      <p
        class="max-w-md"
        style="color: var(--color-on-surface-variant)"
        data-i18n-base
        data-i18n-en="Book a free call to audit your environment and find out exactly what's slowing your deployments — and how to fix them."
        data-i18n-de="Buche ein kostenloses Audit-Gespräch und finde heraus, was deine Deployments ausbremst — und wie du es behebst."
      >Book a free call to audit your environment and find out exactly what's slowing your deployments — and how to fix them.</p>
    </div>

    <div class="border p-8 relative w-full" style="background-color: var(--color-surface-container-lowest); border-color: var(--color-outline-variant); box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15)">
      <div class="absolute top-0 right-0 p-4 font-mono text-[10px] uppercase" style="color: var(--color-outline-variant)">input.yaml</div>

      <form id="contact-form" class="space-y-8">
        <input type="hidden" name="access_key" value="39325897-8e94-46da-b9b8-ac7d6853c960" />
        <input type="hidden" name="subject" value="New Lead — danielvlad.com" />
        <input type="hidden" name="from_name" value="danielvlad.com Contact Form" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div class="grid md:grid-cols-2 gap-8">
          <div>
            <label
              class="block text-[10px] font-mono uppercase mb-2"
              style="color: var(--color-primary)"
              data-i18n-base
              data-i18n-en="Your Name"
              data-i18n-de="Dein Name"
            >Your Name</label>
            <input
              class="w-full px-3 py-3 transition-colors"
              style="background-color: var(--color-surface-container-high); border: none; border-bottom: 2px solid var(--color-outline-variant); color: var(--color-on-surface)"
              placeholder="Your Name"
              type="text"
              name="name"
              required
            />
          </div>
          <div>
            <label
              class="block text-[10px] font-mono uppercase mb-2"
              style="color: var(--color-primary)"
              data-i18n-base
              data-i18n-en="Your Email"
              data-i18n-de="Deine E-Mail"
            >Your Email</label>
            <input
              class="w-full px-3 py-3 transition-colors"
              style="background-color: var(--color-surface-container-high); border: none; border-bottom: 2px solid var(--color-outline-variant); color: var(--color-on-surface)"
              placeholder="email@address.com"
              type="email"
              name="email"
              required
            />
          </div>
        </div>

        <div>
          <label
            class="block text-[10px] font-mono uppercase mb-2"
            style="color: var(--color-primary)"
            data-i18n-base
            data-i18n-en="What's slowing your deployments?"
            data-i18n-de="Was bremst deine Deployments?"
          >What's slowing your deployments?</label>
          <textarea
            class="w-full px-3 py-3 resize-none transition-colors"
            style="background-color: var(--color-surface-container-high); border: none; border-bottom: 2px solid var(--color-outline-variant); color: var(--color-on-surface)"
            placeholder="Describe your infrastructure needs..."
            rows="4"
            name="message"
            required
          ></textarea>
        </div>

        <!-- Inline error message -->
        <div id="form-error" class="hidden font-mono text-[11px] px-4 py-3 border" style="color: #f87171; border-color: #f87171; background-color: rgba(248,113,113,0.05)">
          <span class="material-symbols-outlined text-sm mr-1" style="vertical-align: middle; font-size: 14px;">error</span>
          <span id="form-error-msg">Something went wrong. Please try again or email me directly at {resumeData.email}</span>
        </div>

        <!-- hCaptcha widget -->
        <div class="h-captcha" data-captcha="true" data-theme="dark" data-size="compact"></div>

        <div class="flex flex-col sm:flex-row justify-between items-center pt-4 gap-6">
          <div class="text-[10px] font-mono text-center sm:text-left" style="color: var(--color-outline-variant)">
            <div>
              <span data-i18n-base data-i18n-en="endpoint:" data-i18n-de="endpoint:">endpoint:</span> {resumeData.email}
            </div>
            <div>
              <span data-i18n-base data-i18n-en="status:" data-i18n-de="status:">status:</span> <span data-i18n-base data-i18n-en="listening_on_all_ports" data-i18n-de="listening_on_all_ports">listening_on_all_ports</span>
            </div>
          </div>

          <div class="flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
            <a href="/dvlad-devops-lp/CV_Daniel_Vlad.pdf" download class="btn-secondary text-center">
              <span class="material-symbols-outlined text-sm mr-2">download</span>
              <span data-i18n-base data-i18n-en="RESUME" data-i18n-de="LEBENSLAUF">RESUME</span>
            </a>
            <button id="submit-btn" type="submit" class="btn-primary w-full sm:w-auto flex items-center justify-center gap-2">
              <span id="submit-label"
                data-i18n-base
                data-i18n-en="DEPLOY"
                data-i18n-de="SENDEN"
              >DEPLOY</span>
              <svg id="submit-spinner" class="hidden animate-spin" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                <path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/>
              </svg>
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  var form = document.getElementById('contact-form');
  var submitBtn = document.getElementById('submit-btn');
  var submitLabel = document.getElementById('submit-label');
  var submitSpinner = document.getElementById('submit-spinner');
  var errorBox = document.getElementById('form-error');
  var errorMsg = document.getElementById('form-error-msg');
  var lang = window.__USER_LANG__ || 'en';

  var errorMessages = {
    en: 'Something went wrong. Please try again or email directly.',
    de: 'Etwas ist schiefgelaufen. Bitte versuche es erneut oder schreibe direkt an: contact@danielvlad.com'
  };
  var captchaMessages = {
    en: 'Please complete the captcha challenge before sending.',
    de: 'Bitte löse zuerst das Captcha, bevor du absendest.'
  };

  form.addEventListener('submit', async function(e) {
    e.preventDefault();

    var hCaptchaToken = form.querySelector('textarea[name=h-captcha-response]').value;
    if (!hCaptchaToken) {
      errorMsg.textContent = captchaMessages[lang];
      errorBox.classList.remove('hidden');
      return;
    }

    errorBox.classList.add('hidden');
    submitBtn.disabled = true;
    var btnLabel = lang === 'de' ? 'SENDEN...' : 'SENDING...';
    submitLabel.textContent = btnLabel;
    submitSpinner.classList.remove('hidden');

    var formData = new FormData(form);
    var data = Object.fromEntries(formData.entries());

    try {
      var response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        window.location.href = '/dvlad-devops-lp/thank-you';
      } else {
        var body = await response.json().catch(function() { return {}; });
        throw new Error(body.message || 'Server error ' + response.status);
      }
    } catch (err) {
      errorMsg.textContent = err.message ? err.message : errorMessages[lang];
      errorBox.classList.remove('hidden');
      submitBtn.disabled = false;
      submitLabel.textContent = lang === 'de' ? 'SENDEN' : 'DEPLOY';
      submitSpinner.classList.add('hidden');
    }
  });
</script>
