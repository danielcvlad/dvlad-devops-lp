---
---

<section class="py-24 border-t" style="background-color: var(--color-background); border-color: rgba(65, 71, 84, 0.1)" id="services">
  <div class="max-w-6xl mx-auto px-6">
    <div class="text-center mb-16">
      <h2
        class="text-3xl font-bold headline-font tracking-tighter uppercase mb-4"
        data-i18n-base
        data-i18n-en="What I Do"
        data-i18n-de="Was ich mache"
      >What I Do</h2>
      <p
        class="max-w-2xl mx-auto"
        style="color: var(--color-on-surface-variant)"
        data-i18n-base
        data-i18n-en="From bottleneck to deployment — I help engineering teams ship faster without sacrificing security or stability."
        data-i18n-de="Vom Flaschenhals zum Deployment — ich helfe Engineering-Teams, schneller zu shippen, ohne Sicherheit oder Stabilität zu opfern."
      >From bottleneck to deployment — I help engineering teams ship faster without sacrificing security or stability.</p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
      <!-- CI/CD Optimization -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(52, 229, 7, 0.1)">
          <span class="material-symbols-outlined text-2xl text-primary">rocket_launch</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-primary)"
          data-i18n-base data-i18n-en="CI/CD Pipeline Optimization" data-i18n-de="CI/CD-Pipeline-Optimierung"
        >CI/CD Pipeline Optimization</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)"
          data-i18n-base
          data-i18n-en="Cut deployment time from hours to minutes. Automated testing, parallel jobs, and zero-downtime releases."
          data-i18n-de="Deploy-Zeiten von Stunden auf Minuten reduzieren. Automatisiertes Testen, parallele Jobs und Zero-Downtime-Releases."
        >Cut deployment time from hours to minutes. Automated testing, parallel jobs, and zero-downtime releases.</p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)"
          data-i18n-base data-i18n-en="Jenkins · GitHub Actions · Azure DevOps" data-i18n-de="Jenkins · GitHub Actions · Azure DevOps"
        >Jenkins · GitHub Actions · Azure DevOps</div>
      </div>

      <!-- Infrastructure Migration -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(171, 199, 255, 0.1)">
          <span class="material-symbols-outlined text-2xl text-secondary">cloud_sync</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-secondary)"
          data-i18n-base data-i18n-en="Cloud Infrastructure Migration" data-i18n-de="Cloud-Infrastruktur-Migration"
        >Cloud Infrastructure Migration</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)"
          data-i18n-base
          data-i18n-en="Move from on-prem to cloud-native. Azure, AWS, GCP — designed for scale, built for cost efficiency."
          data-i18n-de="Von On-Prem zu Cloud-Native. Azure, AWS, GCP — für Skalierbarkeit entworfen, für Kosteneffizienz gebaut."
        >Move from on-prem to cloud-native. Azure, AWS, GCP — designed for scale, built for cost efficiency.</p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)"
          data-i18n-base data-i18n-en="Terraform · Bicep · ARM Templates" data-i18n-de="Terraform · Bicep · ARM Templates"
        >Terraform · Bicep · ARM Templates</div>
      </div>

      <!-- Security Hardening -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(52, 229, 7, 0.1)">
          <span class="material-symbols-outlined text-2xl text-primary">security</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-primary)"
          data-i18n-base data-i18n-en="Security &amp; Compliance" data-i18n-de="Sicherheit &amp; Compliance"
        >Security &amp; Compliance</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)"
          data-i18n-base
          data-i18n-en="Vault, zero-trust networks, policy-as-code. Pass audits without slowing down your team."
          data-i18n-de="Vault, Zero-Trust-Netze, Policy-as-Code. Audits bestehen, ohne das Team auszubremsen."
        >Vault, zero-trust networks, policy-as-code. Pass audits without slowing down your team.</p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)"
          data-i18n-base data-i18n-en="HashiCorp Vault · Azure Policy · Sentinel" data-i18n-de="HashiCorp Vault · Azure Policy · Sentinel"
        >HashiCorp Vault · Azure Policy · Sentinel</div>
      </div>

      <!-- DevOps Audit -->
      <div class="project-card text-center">
        <div class="w-12 h-12 mx-auto mb-6 flex items-center justify-center rounded-full" style="background-color: rgba(171, 199, 255, 0.1)">
          <span class="material-symbols-outlined text-2xl text-secondary">manage_search</span>
        </div>
        <h3 class="text-lg font-bold headline-font mb-3" style="color: var(--color-secondary)"
          data-i18n-base data-i18n-en="Infrastructure Audit" data-i18n-de="Infrastruktur-Audit"
        >Infrastructure Audit</h3>
        <p class="text-sm leading-relaxed mb-4" style="color: var(--color-on-surface-variant)"
          data-i18n-base
          data-i18n-en="30-minute free review of your deployment pipeline. You'll leave with 3 actionable improvements — no strings."
          data-i18n-de="30-minütiges kostenloses Review deiner Deployment-Pipeline. Du gehst mit 3 umsetzbaren Verbesserungen raus — unverbindlich."
        >30-minute free review of your deployment pipeline. You'll leave with 3 actionable improvements — no strings.</p>
        <div class="text-[9px] font-mono" style="color: var(--color-outline-variant)"
          data-i18n-base data-i18n-en="Review · Recommendations · Roadmap" data-i18n-de="Review · Empfehlungen · Roadmap"
        >Review · Recommendations · Roadmap</div>
      </div>
    </div>

    <!-- CTA -->
    <div class="text-center mt-12">
      <a href="#contact" class="btn-primary inline-flex items-center gap-2"
        data-i18n-base data-i18n-en="BOOK FREE AUDIT CALL" data-i18n-de="KOSTENLOSES AUDIT BUCHEN">
        <span class="material-symbols-outlined text-sm">calendar_month</span>
        BOOK FREE AUDIT CALL
      </a>
    </div>
  </div>
</section>
