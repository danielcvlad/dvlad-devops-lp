---
import { resumeData } from '../data/resume';
---

<section class="max-w-6xl mx-auto px-6 py-12 md:py-24" id="about">
  <!-- Terminal Window -->
  <div class="border relative overflow-hidden" style="background-color: var(--color-surface-container-lowest); border-color: rgba(65, 71, 84, 0.2)">
    <!-- Terminal Header - subtle -->
    <div class="px-4 py-2 flex items-center gap-2" style="background-color: var(--color-surface-container-low)">
      <span class="text-[10px] font-mono" style="color: var(--color-on-surface-variant); opacity: 0.5">bash — architect@dvlad-system</span>
    </div>

    <!-- Terminal Content - below header -->
    <div class="p-8 md:p-12 relative">
      <div class="mb-6">
        <span class="font-mono mr-2" style="color: var(--color-primary)">&gt;</span>
        <span class="text-sm font-mono" style="color: var(--color-on-surface-variant)">init --profile "{resumeData.name}"</span>
      </div>

      <h1 class="text-4xl md:text-6xl font-bold headline-font leading-tight tracking-tighter mb-4">
        Ship Your Code to Production.
      </h1>
      <p class="text-2xl md:text-3xl font-light mb-8" style="color: var(--color-primary)">
        Faster & More Secure.
      </p>

      <p class="text-xl md:text-2xl max-w-3xl mb-8 font-light leading-relaxed" style="color: var(--color-secondary)">
        DevOps Engineer | Cloud Solutions Architect
      </p>

      <div class="grid md:grid-cols-3 gap-8 pt-6" style="border-top: 1px solid rgba(65, 71, 84, 0.1)">
        <div>
          <div class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--color-primary)">STATUS</div>
          <div class="flex items-center gap-2">
            <span class="w-2 h-2 rounded-full" style="background-color: var(--color-primary); animation: pulse 2s infinite;"></span>
            <span class="text-sm" style="color: var(--color-on-surface)">Available for projects</span>
          </div>
        </div>
        <div>
          <div class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--color-secondary)">CORE_STACK</div>
          <div class="text-sm" style="color: var(--color-on-surface)">Azure, Kubernetes, Terraform, CI/CD</div>
        </div>
        <div>
          <div class="text-xs font-mono uppercase tracking-widest mb-2" style="color: var(--color-on-surface-variant)">LOCATION</div>
          <div class="text-sm" style="color: var(--color-on-surface)">Munich // Remote — Global Node</div>
        </div>
      </div>

      <style>
        @keyframes pulse {
          0%, 100% { opacity: 1; }
          50% { opacity: 0.4; }
        }
      </style>

      <!-- Visual Bleed Background (Terraform code) -->
      <div class="absolute -right-20 -bottom-20 opacity-5 pointer-events-none hidden lg:block">
        <div class="text-[8px] font-mono leading-none" style="color: var(--color-primary)">
          <pre>resource "azurerm_kubernetes_cluster" "prod" &#123;
    name                = "dvlad-architect-cluster"
    location            = "West Europe"
    dns_prefix          = "dvlad-prod"
    default_node_pool &#123;
        name       = "default"
        node_count = 3
        vm_size    = "Standard_D2_v2"
    &#125;
    identity &#123;
        type = "SystemAssigned"
    &#125;
&#125;</pre>
        </div>
      </div>
    </div>
  </div>
</section>
