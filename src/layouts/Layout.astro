---
import '../styles/global.css';
import faviconSvg from '../assets/favicon.svg';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "DevOps Engineer & Cloud Solutions Architect specializing in orchestrating high-scale infrastructure through Azure, CI/CD automation, and Infrastructure as Code." } = Astro.props;
const faviconUrl = faviconSvg.src;
---

<!doctype html>
<html class="dark" lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={faviconUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;900&family=DM+Sans:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <title>{title}</title>

    <!-- Language detection: runs before page renders to prevent flash of wrong language -->
    <script is:inline>
      (function() {
        var stored = localStorage.getItem('lang');
        var lang = 'en';
        if (stored && (stored === 'en' || stored === 'de')) {
          lang = stored;
        } else {
          var browserLang = (navigator.language || '').toLowerCase();
          if (browserLang.startsWith('de')) lang = 'de';
        }
        document.documentElement.lang = lang;
        window.__USER_LANG__ = lang;
      })();
    </script>
  </head>
  <body>
    <slot />
    <script src="https://web3forms.com/client/script.js" async defer></script>
    <script is:inline>
      // Theme toggle
      function toggleTheme() {
        var html = document.documentElement;
        if (html.classList.contains('dark')) {
          html.classList.remove('dark');
          html.classList.add('light');
          localStorage.setItem('theme', 'light');
        } else {
          html.classList.remove('light');
          html.classList.add('dark');
          localStorage.setItem('theme', 'dark');
        }
        updateThemeIcon();
      }
      function updateThemeIcon() {
        var btn = document.getElementById('theme-toggle');
        var btnFloat = document.getElementById('theme-toggle-float');
        var isDark = document.documentElement.classList.contains('dark');
        var moonIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>';
        var sunIcon = '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>';
        var icon = isDark ? moonIcon : sunIcon;
        if (btn) btn.innerHTML = icon;
        if (btnFloat) btnFloat.innerHTML = icon;
      }
      // Apply saved theme on load
      document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('theme');
        if (saved === 'light') {
          document.documentElement.classList.remove('dark');
          document.documentElement.classList.add('light');
        }
        updateThemeIcon();
      });

      // Language switcher: apply translations after DOM is ready
      function applyTranslations(lang) {
        var el = document.querySelector('[data-i18n="' + lang + '"]');
        if (!el) return;
        var key = el.getAttribute('data-i18n-key');
        var params = JSON.parse(el.getAttribute('data-i18n-params') || '{}');
        el.textContent = el.getAttribute('data-i18n-' + lang) || el.textContent;
      }
      document.querySelectorAll('[data-i18n-base]').forEach(function(el) {
        var base = el.getAttribute('data-i18n-base');
        var enText = el.getAttribute('data-i18n-en') || '';
        var deText = el.getAttribute('data-i18n-de') || enText;
        var params = el.getAttribute('data-i18n-params') || '';
        var lang = window.__USER_LANG__ || 'en';
        var text = lang === 'de' ? deText : enText;
        if (params) {
          try { var p = JSON.parse(params); for (var k in p) { text = text.replace('{' + k + '}', p[k]); } } catch(e) {}
        }
        el.textContent = text;
      });
    </script>
  </body>
</html>

<style is:global>
  .material-symbols-outlined {
    font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
  }

  #theme-toggle {
    transition: transform 0.2s ease;
  }
  #theme-toggle:hover {
    transform: scale(1.1);
  }
  #lamp-svg {
    transition: all 0.3s ease;
  }
  html.dark #theme-toggle svg {
    filter: drop-shadow(0 0 4px rgba(52, 229, 7, 0.5));
    color: var(--color-primary);
  }
  html.light #theme-toggle svg {
    filter: drop-shadow(0 0 3px rgba(0, 120, 212, 0.4));
    color: var(--color-primary);
  }
</style>
